struct Reading { celsius: float, sensor: string }

fun main(): int {
    print(1.5);
    print(2.0);
    print(1.0 / 3.0);
    print(-0.0);
    print(1000000000000000000000.0);
    print(0.0000000001);
    print(0.1 + 0.2);
    print(0.0 / 0.0);
    print(1.0 / 0.0);
    print(-1.0 / 0.0);

    var half: float? = null;
    print(half);
    half = 0.5;
    print(half);
    print(half ?? 0.0);

    print([0.25, -2.5]);
    print(Reading { celsius: 21.375, sensor: "attic" });
    return 42;
}
