refstruct Node { value: int, next: Node? }

fun main(): int {
    var head: Node? = null;
    var i: int = 0;
    while i < 1000000 {
        head = Node { value: i % 100, next: head };
        i = i + 1;
    }
    var total: int = 0;
    var pass: int = 0;
    while pass < 10 {
        var cur: Node? = head;
        while cur != null {
            total = total + cur.value;
            cur = cur.next;
        }
        pass = pass + 1;
    }
    return total % 251;
}
