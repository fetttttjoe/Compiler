fun main(): int {
    var xs: int[] = [];
    var i: int = 0;
    while i < 5000000 {
        push(xs, i % 1000);
        i = i + 1;
    }
    var total: int = 0;
    var pass: int = 0;
    while pass < 10 {
        for x in xs {
            total = total + x;
        }
        pass = pass + 1;
    }
    return total % 251;
}
