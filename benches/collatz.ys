fun steps(start: int): int {
    var n: int = start;
    var s: int = 0;
    while n != 1 {
        if n % 2 == 0 { n = n / 2; } else { n = 3 * n + 1; }
        s = s + 1;
    }
    return s;
}

fun main(): int {
    var total: int = 0;
    var i: int = 1;
    while i < 300000 {
        total = total + steps(i);
        i = i + 1;
    }
    return total % 251;
}
